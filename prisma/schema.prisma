// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  VAN
  TRUCK
  MINI
  BUS
  CAR
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum LicenseCategory {
  LMV
  HMV
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  ACTIVE
  COMPLETED
}

enum ExpenseType {
  TOLL
  MISC
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           Role
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
}

model Vehicle {
  id                 String        @id @default(cuid())
  registrationNumber String        @unique
  name               String
  type               VehicleType
  maxLoadKg          Int
  odometer           Int
  acquisitionCost    Int
  region             String?
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now())

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
}

model Driver {
  id              String          @id @default(cuid())
  name            String
  licenseNumber   String          @unique
  licenseCategory LicenseCategory
  licenseExpiry   DateTime
  contact         String
  safetyScore     Int
  status          DriverStatus    @default(AVAILABLE)
  createdAt       DateTime        @default(now())

  trips Trip[]
}

model Trip {
  id                 String     @id @default(cuid())
  code               String     @unique
  source             String
  destination        String
  vehicleId          String?
  driverId           String?
  cargoWeightKg      Int
  plannedDistanceKm  Int
  status             TripStatus @default(DRAFT)
  finalOdometer      Int?
  fuelConsumedLiters Float?
  revenue            Int?
  createdAt          DateTime   @default(now())
  dispatchedAt       DateTime?
  completedAt        DateTime?

  vehicle  Vehicle?  @relation(fields: [vehicleId], references: [id])
  driver   Driver?   @relation(fields: [driverId], references: [id])
  fuelLogs FuelLog[]
  expenses Expense[]
}

model MaintenanceLog {
  id          String            @id @default(cuid())
  vehicleId   String
  serviceType String
  cost        Int
  date        DateTime
  status      MaintenanceStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  tripId    String?
  date      DateTime
  liters    Float
  cost      Int
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])
}

model Expense {
  id        String      @id @default(cuid())
  vehicleId String?
  tripId    String?
  type      ExpenseType
  amount    Int
  note      String?
  createdAt DateTime    @default(now())

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  trip    Trip?    @relation(fields: [tripId], references: [id])
}

model OrgSettings {
  id           String @id @default(cuid())
  depotName    String @default("Gandhinagar Depot GJ4")
  currency     String @default("INR")
  distanceUnit String @default("Kilometers")
}
